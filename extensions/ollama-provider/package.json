{
  "name": "@ouroboros/ollama-provider",
  "version": "1.0.0-beta.2",
  "description": "Ollama Provider Extension for Ouroboros Code - Local LLM inference",
  "main": "dist/provider.js",
  "types": "dist/provider.d.ts",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git", 
    "url": "https://github.com/ouroboros-ai/ollama-provider"
  },
  "keywords": [
    "ollama",
    "llm",
    "local-inference",
    "privacy",
    "ouroboros",
    "extension",
    "ai"
  ],
  "author": "Ouroboros Development Team",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node tests/integration.js",
    "check-ollama": "node scripts/check-ollama.js",
    "verify-install": "node scripts/verify-install.js",
    "prepack": "npm run build"
  },
  "dependencies": {
    "ollama": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist/**/*",
    "gemini-extension.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}